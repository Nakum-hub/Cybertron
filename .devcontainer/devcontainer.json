{
  "name": "Cybertron",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-22-bookworm",
  "remoteUser": "node",
  "forwardPorts": [
    3000,
    8001
  ],
  "portsAttributes": {
    "3000": {
      "label": "Cybertron Frontend",
      "onAutoForward": "openBrowser"
    },
    "8001": {
      "label": "Cybertron Backend API",
      "onAutoForward": "notify"
    }
  },
  "postCreateCommand": "npm install --prefix workspace/app/frontend && npm install --prefix workspace/app/backend",
  "customizations": {
    "vscode": {
      "extensions": [
        "github.copilot",
        "github.copilot-chat",
        "github.vscode-pull-request-github",
        "github.vscode-github-actions",
        "dbaeumer.vscode-eslint",
        "ms-playwright.playwright",
        "redhat.vscode-yaml",
        "humao.rest-client"
      ]
    }
  }
}
