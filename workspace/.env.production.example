# Cybertron Production Environment Configuration
# Copy this file to .env and fill in all required values before deployment.
# Variables marked [REQUIRED] must be set. Others have sensible defaults.

# ── Server ────────────────────────────────────────────────────────────
PORT=8001
HOST=0.0.0.0
NODE_ENV=production
APP_VERSION=1.0.0
REGION=us-east-1
# Set FRONTEND_PORT=127.0.0.1:8080 when using docker-compose.prod.edge.yml
FRONTEND_PORT=80

# [REQUIRED] Must be https:// in production
FRONTEND_ORIGIN=https://cybertron.example.com

# [REQUIRED] Comma-separated, no wildcards or localhost allowed in production
CORS_ALLOWED_ORIGINS=https://cybertron.example.com

# ── Authentication ────────────────────────────────────────────────────
# [REQUIRED] Must be jwt_hs256 in production (demo mode is blocked)
AUTH_MODE=jwt_hs256

# [REQUIRED] Minimum 32-character random secret for JWT signing
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET_AT_LEAST_32_CHARS
JWT_ISSUER=cybertron
JWT_AUDIENCE=cybertron-api
JWT_CLOCK_SKEW_SECONDS=30

AUTH_TOKEN_TTL_MS=28800000
AUTH_MAX_SESSIONS=50000
REFRESH_TOKEN_TTL_MS=2592000000
PASSWORD_HASH_ROUNDS=12
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_MS=900000

# Cookie security (all enforced in production)
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=cybertron.example.com

# [REQUIRED] CSRF must be enabled in production
CSRF_ENABLED=true
ENFORCE_ORIGIN_VALIDATION=true
ALLOW_INSECURE_DEMO_AUTH=false
ALLOW_PUBLIC_REGISTRATION=false

# [REQUIRED] Auth must be required for all endpoint groups in production
REQUIRE_AUTH_FOR_THREAT_ENDPOINTS=true
REQUIRE_AUTH_FOR_PLATFORM_ENDPOINTS=true
METRICS_REQUIRE_AUTH=true
METRICS_AUTH_TOKEN=CHANGE_ME_METRICS_TOKEN

# ── Database ──────────────────────────────────────────────────────────
# Required by the bundled production compose stack
POSTGRES_DB=cybertron
POSTGRES_USER=cybertron
POSTGRES_PASSWORD=CHANGE_ME_TO_A_DATABASE_PASSWORD_AT_LEAST_24_CHARS

# [REQUIRED] PostgreSQL connection string
DATABASE_URL=postgres://cybertron:CHANGE_ME_TO_A_DATABASE_PASSWORD_AT_LEAST_24_CHARS@postgres:5432/cybertron
DB_SSL_MODE=verify-full
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECT_TIMEOUT_MS=5000
DB_STATEMENT_TIMEOUT_MS=10000
DB_AUTO_MIGRATE=true

# ── Redis ─────────────────────────────────────────────────────────────
# Required by the bundled production compose stack
REDIS_PASSWORD=CHANGE_ME_TO_A_REDIS_PASSWORD_AT_LEAST_24_CHARS

# [REQUIRED] Redis connection string for sessions, rate limiting, auth revocation
REDIS_URL=redis://:CHANGE_ME_TO_A_REDIS_PASSWORD_AT_LEAST_24_CHARS@redis:6379
REDIS_CONNECT_TIMEOUT_MS=2000
REDIS_CONNECT_MAX_RETRIES=4

# ── Rate Limiting ─────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=200
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX_REQUESTS=25
AUTH_IDENTITY_RATE_LIMIT_MAX_REQUESTS=8
MAX_CONCURRENT_REQUESTS=2000
TRUST_PROXY=true

# ── Request Timeouts ──────────────────────────────────────────────────
REQUEST_TIMEOUT_MS=15000
HEADERS_TIMEOUT_MS=16000
KEEP_ALIVE_TIMEOUT_MS=5000

# ── Report Storage ────────────────────────────────────────────────────
# Use 's3' for production cloud storage; 'local' for single-server deployments
REPORT_STORAGE_DRIVER=s3
REPORT_UPLOAD_MAX_BYTES=15728640
REPORT_UPLOAD_ALLOWED_MIME_TYPES=application/pdf,text/csv,application/json
REPORT_RETENTION_DAYS=365

# S3 configuration (required when REPORT_STORAGE_DRIVER=s3)
REPORT_STORAGE_S3_BUCKET=cybertron-reports
REPORT_STORAGE_S3_REGION=us-east-1
REPORT_STORAGE_S3_ENDPOINT=
REPORT_STORAGE_S3_ACCESS_KEY_ID=CHANGE_ME
REPORT_STORAGE_S3_SECRET_ACCESS_KEY=CHANGE_ME
REPORT_STORAGE_S3_FORCE_PATH_STYLE=false

# ── LLM Provider (optional) ──────────────────────────────────────────
# Set to 'openai' for launch-grade AI features, or replace with a secure
# OpenAI-compatible provider URL/model pair if you operate your own endpoint.
LLM_PROVIDER=openai
OPENAI_API_KEY=CHANGE_ME_OPENAI_API_KEY
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OLLAMA_URL=
OLLAMA_MODEL=llama3.1
LLM_REQUEST_TIMEOUT_MS=120000

# ── Public Edge / TLS ────────────────────────────────────────────────
# Use with docker-compose.prod.edge.yml if you want Caddy-managed TLS in front
# of the Cybertron frontend/backend stack.
CYBERTRON_DOMAIN=cybertron.example.com
CYBERTRON_TLS_EMAIL=security@example.com
EDGE_HTTP_PORT=80
EDGE_HTTPS_PORT=443

# ── Threat Intel / NVD (optional) ─────────────────────────────────────
NVD_FEED_URL=https://services.nvd.nist.gov/rest/json/cves/2.0
NVD_API_KEY=
NVD_REQUEST_TIMEOUT_MS=20000
URLHAUS_ENABLED=false
URLHAUS_REQUEST_TIMEOUT_MS=15000

# ── External Threat Connectors (optional, must use https in production) ─
WAZUH_API_URL=
WAZUH_API_TOKEN=
MISP_API_URL=
MISP_API_KEY=
OPENCTI_API_URL=
OPENCTI_API_TOKEN=
THEHIVE_API_URL=
THEHIVE_API_TOKEN=
CONNECTOR_TIMEOUT_MS=6000

# ── OAuth2 Social Login (optional) ────────────────────────────────────
# Register an OAuth app with each provider. Set ALLOW_PUBLIC_REGISTRATION=true
# above if you want new users to be created automatically via OAuth sign-in.
#
# Callback URLs to register with each provider (replace domain with yours):
#   Google:    https://cybertron.example.com/api/v1/auth/oauth/google/callback
#   Microsoft: https://cybertron.example.com/api/v1/auth/oauth/microsoft/callback
#   GitHub:    https://cybertron.example.com/api/v1/auth/oauth/github/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_CALLBACK_BASE_URL=https://cybertron.example.com

# ── Device Fingerprinting ─────────────────────────────────────────────
MAX_REGISTRATIONS_PER_FINGERPRINT=3
FINGERPRINT_WINDOW_MS=86400000

# ── Frontend (build-time) ─────────────────────────────────────────────
VITE_APP_NAME=Cybertron
VITE_API_BASE_URL=/api
VITE_REQUEST_TIMEOUT_MS=15000
VITE_ENABLE_API_OBSERVABILITY=true
VITE_ANALYTICS_ENABLED=true
