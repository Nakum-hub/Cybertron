# Cybertron local-production validation environment
# Copy this file to .env.production.local for Docker-based local validation only.
# Do not use these values for internet-exposed deployments.

APP_VERSION=1.0.0-local-prod
REGION=local-docker
FRONTEND_PORT=8088
FRONTEND_ORIGIN=http://127.0.0.1:8088
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8088
LOCAL_PRODUCTION_VALIDATION=true

AUTH_MODE=jwt_hs256
JWT_SECRET=cybertron-local-docker-jwt-secret-1234567890
JWT_ISSUER=cybertron
JWT_AUDIENCE=cybertron-api
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SAMESITE=lax
ALLOW_PUBLIC_REGISTRATION=false

METRICS_AUTH_TOKEN=cybertron-local-metrics-token-123456

POSTGRES_USER=cybertron
POSTGRES_PASSWORD=cybertron_prod_password
POSTGRES_DB=cybertron
DATABASE_URL=postgresql://cybertron:cybertron_prod_password@postgres:5432/cybertron
DB_SSL_MODE=disable

REDIS_PASSWORD=cybertron_redis_password
REDIS_URL=redis://:cybertron_redis_password@redis:6379

REPORT_STORAGE_DRIVER=local
LLM_PROVIDER=none
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OLLAMA_URL=
OLLAMA_MODEL=llama3.1
LLM_REQUEST_TIMEOUT_MS=20000
