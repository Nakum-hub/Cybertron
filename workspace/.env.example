# Copy to `.env` for local development.

APP_VERSION=0.3.0-dev
REGION=local-dev

FRONTEND_PORT=3000
BACKEND_PORT=8001
POSTGRES_PORT=5432
REDIS_PORT=6379

FRONTEND_ORIGIN=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

AUTH_MODE=jwt_hs256
ALLOW_INSECURE_DEMO_AUTH=false
ALLOW_PUBLIC_REGISTRATION=true
REDIS_URL=redis://redis:6379
REDIS_CONNECT_TIMEOUT_MS=2000
REDIS_CONNECT_MAX_RETRIES=4
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_PATH=/
AUTH_ACCESS_COOKIE_NAME=ct_access
AUTH_REFRESH_COOKIE_NAME=ct_refresh
AUTH_CSRF_COOKIE_NAME=ct_csrf
CSRF_ENABLED=true
REQUIRE_DATABASE_FOR_CI=false
STRICT_DEPENDENCIES=true

# Set this before enabling AUTH_MODE=jwt_hs256.
JWT_SECRET=dev-jwt-secret-change-me
JWT_ISSUER=
JWT_AUDIENCE=
JWT_CLOCK_SKEW_SECONDS=30

AUTH_TOKEN_TTL_MS=3600000
REFRESH_TOKEN_TTL_MS=2592000000
PASSWORD_RESET_TOKEN_TTL_MS=1800000
PASSWORD_HASH_ROUNDS=12
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_MS=900000
AUTH_MAX_SESSIONS=50000

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=200
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX_REQUESTS=25
AUTH_IDENTITY_RATE_LIMIT_MAX_REQUESTS=8
REPORT_RATE_LIMIT_WINDOW_MS=60000
REPORT_RATE_LIMIT_MAX_REQUESTS=80
MAX_CONCURRENT_REQUESTS=2000

REQUEST_TIMEOUT_MS=15000
HEADERS_TIMEOUT_MS=16000
KEEP_ALIVE_TIMEOUT_MS=5000

METRICS_REQUIRE_AUTH=false
METRICS_AUTH_TOKEN=dev-metrics-token
REQUIRE_AUTH_FOR_THREAT_ENDPOINTS=false
REQUIRE_AUTH_FOR_PLATFORM_ENDPOINTS=true

PUBLIC_API_BASE_URL=/api
PUBLIC_AUTH_LOGIN_PATH=/v1/auth/login
PUBLIC_AUTH_TOKEN_PATH=/v1/auth/token
PUBLIC_AUTH_ME_PATH=/v1/auth/me
PUBLIC_AUTH_LOGOUT_PATH=/v1/auth/logout
PUBLIC_THREAT_SUMMARY_PATH=/v1/threats/summary
PUBLIC_THREAT_INCIDENTS_PATH=/v1/threats/incidents
PUBLIC_SYSTEM_HEALTH_PATH=/v1/system/health
PUBLIC_PLATFORM_APPS_PATH=/v1/platform/apps
PUBLIC_REPORTS_PATH=/v1/reports
PUBLIC_REPORT_UPLOAD_PATH=/v1/reports/upload
PUBLIC_REPORT_DOWNLOAD_PATH_TEMPLATE=/v1/reports/{reportId}/download
PUBLIC_ANALYTICS_ENABLED=true
PUBLIC_ENTERPRISE_MODE=true

# ── Frontend (Vite) Environment Variables ─────────────────────────────
# Vite exposes only variables prefixed with VITE_ to the frontend.
# The PUBLIC_ variables above are backend-only; use these VITE_ versions
# for frontend configuration.

VITE_API_BASE_URL=/api
VITE_REQUEST_TIMEOUT_MS=15000
VITE_API_RETRY_COUNT=2
VITE_API_RETRY_BASE_DELAY_MS=250
VITE_ENABLE_API_OBSERVABILITY=true
VITE_AUTH_LOGIN_URL=
VITE_AUTH_MODE=jwt_hs256
VITE_DEMO_AUTH_ENABLED=false
VITE_AUTH_TRANSPORT=cookie
VITE_CSRF_ENABLED=true
VITE_CSRF_HEADER_NAME=x-csrf-token
VITE_CSRF_COOKIE_NAME=ct_csrf
VITE_AUTH_LOGIN_PATH=/v1/auth/login
VITE_AUTH_TOKEN_PATH=/v1/auth/token
VITE_AUTH_ME_PATH=/v1/auth/me
VITE_AUTH_LOGOUT_PATH=/v1/auth/logout
VITE_TENANTS_PATH=/v1/tenants
VITE_PRODUCTS_PATH=/v1/products
VITE_TENANT_PRODUCTS_PATH_TEMPLATE=/v1/tenants/{tenant}/products
VITE_TENANT_FEATURE_FLAGS_PATH_TEMPLATE=/v1/tenants/{tenant}/feature-flags
VITE_MODULES_PATH=/v1/modules
VITE_BILLING_USAGE_PATH=/v1/billing/usage
VITE_BILLING_CREDITS_PATH=/v1/billing/credits
VITE_THREAT_SUMMARY_PATH=/v1/threats/summary
VITE_THREAT_INCIDENTS_PATH=/v1/threats/incidents
VITE_SYSTEM_HEALTH_PATH=/v1/system/health
VITE_PLATFORM_APPS_PATH=/v1/platform/apps
VITE_REPORTS_PATH=/v1/reports
VITE_REPORT_UPLOAD_PATH=/v1/reports/upload
VITE_REPORT_DOWNLOAD_PATH_TEMPLATE=/v1/reports/{reportId}/download
VITE_REQUIRE_AUTH_FOR_THREAT_ENDPOINTS=false
VITE_REQUIRE_AUTH_FOR_PLATFORM_ENDPOINTS=true
VITE_STRICT_DEPENDENCIES=true
VITE_ANALYTICS_ENABLED=true
VITE_ENTERPRISE_MODE=true

POSTGRES_DB=cybertron
POSTGRES_USER=cybertron
POSTGRES_PASSWORD=cybertron_dev_password
DATABASE_URL=postgresql://cybertron:cybertron_dev_password@postgres:5432/cybertron
DB_SSL_MODE=disable
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECT_TIMEOUT_MS=5000
DB_STATEMENT_TIMEOUT_MS=10000
DB_AUTO_MIGRATE=true

WAZUH_API_URL=
WAZUH_API_TOKEN=
MISP_API_URL=
MISP_API_KEY=
OPENCTI_API_URL=
OPENCTI_API_TOKEN=
THEHIVE_API_URL=
THEHIVE_API_TOKEN=
CONNECTOR_TIMEOUT_MS=6000

REPORT_STORAGE_DRIVER=local
REPORT_STORAGE_LOCAL_PATH=/srv/cybertron/uploads/reports
REPORT_UPLOAD_MAX_BYTES=15728640
REPORT_UPLOAD_ALLOWED_MIME_TYPES=application/pdf,text/csv,application/json
REPORT_RETENTION_DAYS=365
REPORT_RETENTION_CLEANUP_INTERVAL_MS=21600000
REPORT_RETENTION_BATCH_SIZE=200
REPORT_STORAGE_S3_BUCKET=
REPORT_STORAGE_S3_REGION=us-east-1
REPORT_STORAGE_S3_ENDPOINT=
REPORT_STORAGE_S3_ACCESS_KEY_ID=
REPORT_STORAGE_S3_SECRET_ACCESS_KEY=
REPORT_STORAGE_S3_FORCE_PATH_STYLE=true

# Phase 3 AI upload and evidence handling
MAX_UPLOAD_MB=10
AI_UPLOAD_MAX_BYTES=10485760
COMPLIANCE_EVIDENCE_ALLOWED_MIME_TYPES=application/pdf,text/csv,application/json

# Phase 3 LLM provider settings
LLM_PROVIDER=none
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OLLAMA_URL=
OLLAMA_MODEL=llama3.1
LLM_REQUEST_TIMEOUT_MS=20000

# Threat Intel NVD ingestion
NVD_FEED_URL=https://services.nvd.nist.gov/rest/json/cves/2.0
NVD_API_KEY=
NVD_REQUEST_TIMEOUT_MS=20000
NVD_RESULTS_PER_PAGE=200
NVD_SYNC_MAX_ENTRIES=400
NVD_SYNC_BACKOFF_BASE_MS=30000
NVD_SYNC_BACKOFF_MAX_MS=900000

# ── OAuth2 Social Login (optional) ────────────────────────────────────
# To enable OAuth, register an app with each provider and set the client
# ID and secret below. Set ALLOW_PUBLIC_REGISTRATION=true to allow new
# users to sign up via OAuth (already set above for dev).
#
# Callback URLs to register with each provider:
#   Google:    http://localhost:3000/api/v1/auth/oauth/google/callback
#   Microsoft: http://localhost:3000/api/v1/auth/oauth/microsoft/callback
#   GitHub:    http://localhost:3000/api/v1/auth/oauth/github/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_CALLBACK_BASE_URL=http://localhost:3000

# ── OIDC / Enterprise SSO (optional) ─────────────────────────────────
# Generic OpenID Connect provider (e.g., Okta, Auth0, Keycloak, Azure AD).
# To enable, set OIDC_ISSUER_URL and register a client with your provider.
#   Callback URL: http://localhost:3000/api/v1/auth/oauth/oidc/callback
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_SCOPES=openid email profile
OIDC_AUDIENCE=

# ── Redis Authentication (optional) ──────────────────────────────────
# Set REDIS_PASSWORD when running Redis with --requirepass.
# For local dev without auth, leave blank.
REDIS_PASSWORD=
REDIS_USERNAME=
