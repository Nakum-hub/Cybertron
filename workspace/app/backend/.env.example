PORT=8001
HOST=0.0.0.0
NODE_ENV=development
APP_VERSION=0.3.0-dev
REGION=local-dev
FRONTEND_ORIGIN=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Authentication — CHANGED: default to jwt_hs256, demo mode is dev-only
AUTH_MODE=jwt_hs256

# REQUIRED in production: Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_ISSUER=
JWT_AUDIENCE=
JWT_CLOCK_SKEW_SECONDS=30

AUTH_TOKEN_TTL_MS=28800000
AUTH_MAX_SESSIONS=50000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=200
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX_REQUESTS=25
AUTH_IDENTITY_RATE_LIMIT_MAX_REQUESTS=8
MAX_REGISTRATIONS_PER_FINGERPRINT=1
MAX_WORKSPACE_BOOTSTRAPS_PER_NETWORK=3
FINGERPRINT_WINDOW_MS=86400000
MAX_CONCURRENT_REQUESTS=2000
TRUST_PROXY=false
ENFORCE_ORIGIN_VALIDATION=true

# Security defaults — CHANGED: hardened for safety
ALLOW_INSECURE_DEMO_AUTH=false
REQUIRE_AUTH_FOR_THREAT_ENDPOINTS=true
REQUIRE_AUTH_FOR_PLATFORM_ENDPOINTS=true
METRICS_REQUIRE_AUTH=false
METRICS_AUTH_TOKEN=

REQUEST_TIMEOUT_MS=15000
HEADERS_TIMEOUT_MS=16000
KEEP_ALIVE_TIMEOUT_MS=5000

# Cookie settings for cross-origin: use COOKIE_SAME_SITE=none + AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_DOMAIN=

# Public runtime config served at /api/config and /v1/system/config
PUBLIC_API_BASE_URL=/api
PUBLIC_AUTH_LOGIN_PATH=/v1/auth/login
PUBLIC_AUTH_ME_PATH=/v1/auth/me
PUBLIC_AUTH_LOGOUT_PATH=/v1/auth/logout
PUBLIC_THREAT_SUMMARY_PATH=/v1/threats/summary
PUBLIC_THREAT_INCIDENTS_PATH=/v1/threats/incidents
PUBLIC_SYSTEM_HEALTH_PATH=/v1/system/health
PUBLIC_PLATFORM_APPS_PATH=/v1/platform/apps
PUBLIC_REPORTS_PATH=/v1/reports
PUBLIC_REPORT_UPLOAD_PATH=/v1/reports/upload
PUBLIC_REPORT_DOWNLOAD_PATH_TEMPLATE=/v1/reports/{reportId}/download
PUBLIC_ANALYTICS_ENABLED=true

# Persistence (truthful threat data requires DATABASE_URL)
DATABASE_URL=
# REQUIRED in production: Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# POSTGRES_PASSWORD=
DB_SSL_MODE=require
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECT_TIMEOUT_MS=5000
DB_STATEMENT_TIMEOUT_MS=10000
DB_AUTO_MIGRATE=true

# Redis (required in production for distributed auth and rate limiting)
REDIS_URL=
# REQUIRED in production: Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
REDIS_PASSWORD=

# Optional external connectors (used only when configured)
WAZUH_API_URL=
WAZUH_API_TOKEN=
MISP_API_URL=
MISP_API_KEY=
OPENCTI_API_URL=
OPENCTI_API_TOKEN=
THEHIVE_API_URL=
THEHIVE_API_TOKEN=
CONNECTOR_TIMEOUT_MS=6000

# Connector secrets encryption key
# REQUIRED when using connector config storage. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CONNECTOR_SECRETS_KEY=

# Report storage
REPORT_STORAGE_DRIVER=local
REPORT_STORAGE_LOCAL_PATH=../../.runtime/uploads/reports
REPORT_UPLOAD_MAX_BYTES=15728640
REPORT_UPLOAD_ALLOWED_MIME_TYPES=application/pdf,text/csv,application/json
REPORT_RETENTION_DAYS=365
REPORT_RETENTION_CLEANUP_INTERVAL_MS=21600000
REPORT_RETENTION_BATCH_SIZE=200
FREE_PLAN_INCLUDED_UNITS_PER_MONTH=250
PRO_PLAN_INCLUDED_UNITS_PER_MONTH=0
ENTERPRISE_PLAN_INCLUDED_UNITS_PER_MONTH=0
REPORT_STORAGE_S3_BUCKET=
REPORT_STORAGE_S3_REGION=us-east-1
REPORT_STORAGE_S3_ENDPOINT=
REPORT_STORAGE_S3_ACCESS_KEY_ID=
REPORT_STORAGE_S3_SECRET_ACCESS_KEY=
REPORT_STORAGE_S3_FORCE_PATH_STYLE=true

# Threat Intel NVD ingestion
NVD_FEED_URL=https://services.nvd.nist.gov/rest/json/cves/2.0
NVD_API_KEY=
NVD_REQUEST_TIMEOUT_MS=20000
NVD_RESULTS_PER_PAGE=200
NVD_SYNC_MAX_ENTRIES=400
NVD_SYNC_BACKOFF_BASE_MS=30000
NVD_SYNC_BACKOFF_MAX_MS=900000

# LLM provider settings
LLM_PROVIDER=none
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OLLAMA_URL=
OLLAMA_MODEL=llama3.1
LLM_REQUEST_TIMEOUT_MS=120000
LLM_DEFAULT_MAX_TOKENS=1024

# Fine-tuned Cybertron model via vLLM (OpenAI-compatible endpoint)
# Uses the LoRA adapter from ml/outputs/cybertron-qwen25-1_5b-t4-lora
# Launch with: bash ml/start_vllm_openai_lora.sh
LLM_VLLM_BASE_URL=http://vllm:8000/v1
LLM_VLLM_MODEL=cybertron
LLM_VLLM_API_KEY=cybertron-local-key

# Email: choose one provider
EMAIL_PROVIDER=console
EMAIL_FROM_ADDRESS=noreply@cybertron.io
EMAIL_FROM_NAME=Cybertron
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# Stripe billing integration
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO_MONTHLY=
STRIPE_PRICE_ID_PRO_ANNUAL=
STRIPE_PRICE_ID_ENTERPRISE_MONTHLY=

# OpenTelemetry tracing
OTEL_ENABLED=false
OTEL_SERVICE_NAME=cybertron-backend
OTEL_EXPORTER_OTLP_ENDPOINT=
