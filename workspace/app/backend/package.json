{
  "name": "cybertron-backend",
  "private": true,
  "version": "0.1.0",
  "description": "Cybertron backend foundation with security and contract-ready APIs",
  "scripts": {
    "dev": "node server.js",
    "start": "node server.js",
    "db:migrate": "node scripts/migrate.js",
    "bootstrap:admin": "node scripts/bootstrap-admin.js",
    "test:unit": "node --test tests/*.test.js",
    "coverage": "c8 --all --src src --exclude tests --exclude scripts --exclude server.js --report-dir coverage --reporter=text-summary --reporter=lcov --reporter=html node --test tests/*.test.js",
    "qa:smoke": "node scripts/smoke-check.js",
    "qa:cookie-policy": "node scripts/cookie-policy-check.js",
    "qa:reports-unit": "node scripts/report-upload-unit-check.js",
    "qa:red-team": "npm run qa:reports-unit && npm run qa:cookie-policy && node scripts/red-team-check.js",
    "qa:distributed-auth": "node scripts/distributed-auth-check.js",
    "qa:distributed-rate": "node scripts/distributed-rate-check.js",
    "qa:distributed:local": "node scripts/distributed-with-ephemeral-redis.js",
    "qa:phase3": "node scripts/phase3-ai-check.js",
    "qa:failure": "node scripts/failure-check.js",
    "qa:load": "node scripts/load-smoke.js",
    "qa:strict:embedded": "node scripts/qa-embedded-db.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.906.0",
    "@electric-sql/pglite": "^0.3.15",
    "bcryptjs": "^2.4.3",
    "busboy": "^1.6.0",
    "pg": "^8.16.3",
    "redis": "^5.8.2"
  },
  "devDependencies": {
    "@electric-sql/pglite-socket": "^0.0.20",
    "c8": "^10.1.3",
    "redis-memory-server": "^0.16.0"
  },
  "overrides": {
    "fast-xml-parser": "^5.5.3",
    "tar": "^7.5.11"
  }
}
