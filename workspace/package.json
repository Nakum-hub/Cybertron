{
  "name": "cybertron-workspace",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "start": "node scripts/start-dev.js",
    "start:full": "node scripts/start-dev.js",
    "stop": "node scripts/stop-dev.js",
    "stop:full": "node scripts/stop-dev.js",
    "bootstrap:admin": "npm run bootstrap:admin --prefix app/backend --",
    "ml:export:bootstrap": "node ml/export-cybertron-bootstrap-dataset.js",
    "ml:github-models:teacher": "node ml/synthesize-github-models-teacher.js",
    "ml:build:official-corpus": "node ml/build-official-realworld-corpus.js",
    "ml:build:corpus": "node ml/build-training-corpus.js",
    "ml:build:enterprise-corpus": "node ml/build-training-corpus.js --official ml/data/cybertron_official_realworld_sft.jsonl --reviewed ml/data/cybertron_reviewed_sft.jsonl --out ml/data/cybertron_enterprise_training_corpus.jsonl",
    "ml:prepare:lightning": "node ml/prepare-lightning-bundle.js",
    "ml:validate:reviewed": "node ml/validate-reviewed-corpus.js",
    "ml:train:check": "python ml/train_cybertron_lora.py --dataset ml/data/cybertron_bootstrap_sft.jsonl --check-only",
    "ml:train:t4": "bash ml/train_t4_lora.sh",
    "ml:train:h100": "bash ml/train_h100_lora.sh",
    "ml:serve:vllm": "bash ml/start_vllm_openai_lora.sh",
    "clean:runtime": "node scripts/clean-runtime.js",
    "clean:runtime:dry-run": "node scripts/clean-runtime.js --dry-run",
    "start:frontend": "npm run dev --prefix app/frontend",
    "start:backend": "npm run dev --prefix app/backend",
    "build:full": "npm run build:full --prefix app/frontend",
    "qa:smoke": "npm run qa:smoke --prefix app/backend && npm run build --prefix app/frontend && npm run qa:smoke --prefix app/frontend",
    "qa:frontend": "npm run qa:full --prefix app/frontend",
    "qa:security": "npm run qa:security --prefix app/frontend",
    "qa:interaction": "npm run qa:interaction --prefix app/frontend",
    "qa:ui-wiring:transaction": "npm run qa:ui-wiring:transaction --prefix app/frontend",
    "qa:frontend:ui-wiring:transaction": "npm run qa:ui-wiring:transaction --prefix app/frontend",
    "qa:backend": "npm run qa:smoke --prefix app/backend && npm run qa:red-team --prefix app/backend && npm run qa:failure --prefix app/backend",
    "qa:backend:strict": "npm run qa:strict:embedded --prefix app/backend",
    "qa:backend:strict:skip-load": "npm run qa:strict:embedded --prefix app/backend -- --skip-load",
    "qa:backend:coverage": "npm run coverage --prefix app/backend",
    "qa:backend:distributed-auth": "npm run qa:distributed-auth --prefix app/backend",
    "qa:backend:distributed-rate": "npm run qa:distributed-rate --prefix app/backend",
    "qa:backend:distributed:local": "npm run qa:distributed:local --prefix app/backend",
    "qa:distributed:local": "npm run qa:distributed:local --prefix app/backend",
    "qa:backend:distributed": "npm run qa:distributed-auth --prefix app/backend && npm run qa:distributed-rate --prefix app/backend",
    "qa:backend:phase3": "npm run qa:phase3 --prefix app/backend",
    "qa:red-team": "npm run qa:red-team --prefix app/backend",
    "qa:failure": "npm run qa:failure --prefix app/backend",
    "qa:backend:load": "npm run qa:load --prefix app/backend",
    "qa:full": "npm run qa:backend && npm run qa:frontend",
    "qa:plan-access": "node scripts/plan-access-audit.js",
    "qa:connectors": "node scripts/connector-readiness.js",
    "qa:connectors:self-check": "node scripts/connector-readiness-self-check.js",
    "qa:go-live": "node scripts/go-live-readiness.js",
    "qa:go-live:self-check": "node scripts/go-live-readiness-self-check.js",
    "qa:ai:local": "node scripts/local-ai-sweep.js",
    "qa:release": "node scripts/release-preflight.js",
    "qa:release:strict": "node scripts/release-preflight.js --strict",
    "qa:release:self-check": "node scripts/release-preflight-self-check.js && npm run qa:go-live:self-check && npm run qa:connectors:self-check",
    "qa:ci": "npm run qa:release:self-check && npm run qa:release:strict && npm run qa:frontend && npm run qa:backend:strict:skip-load && npm run qa:failure && npm run qa:ui-wiring:transaction && npm run qa:distributed:local",
    "deploy:prod:env:generate": "node scripts/generate-production-env.js",
    "deploy:dev:up": "docker compose -f docker-compose.dev.yml up -d --build",
    "deploy:dev:down": "docker compose -f docker-compose.dev.yml down",
    "deploy:dev:logs": "docker compose -f docker-compose.dev.yml logs -f",
    "deploy:prod:build": "docker compose -f docker-compose.prod.yml build",
    "deploy:prod:up": "docker compose -f docker-compose.prod.yml up -d",
    "deploy:prod:build:local": "docker compose --env-file .env.production.local -f docker-compose.prod.yml build",
    "deploy:prod:up:local": "docker compose --env-file .env.production.local -f docker-compose.prod.yml up -d",
    "deploy:prod:down:local": "docker compose --env-file .env.production.local -f docker-compose.prod.yml down",
    "deploy:prod:s3:build:local": "docker compose --env-file .env.production.s3.local -f docker-compose.prod.yml -f docker-compose.prod.s3.local.yml build",
    "deploy:prod:s3:up:local": "docker compose --env-file .env.production.s3.local -f docker-compose.prod.yml -f docker-compose.prod.s3.local.yml up -d",
    "deploy:prod:s3:down:local": "docker compose --env-file .env.production.s3.local -f docker-compose.prod.yml -f docker-compose.prod.s3.local.yml down",
    "deploy:prod:down": "docker compose -f docker-compose.prod.yml down",
    "deploy:prod:logs": "docker compose -f docker-compose.prod.yml logs -f",
    "deploy:prod:bootstrap-admin": "node scripts/prod-bootstrap-admin.js",
    "deploy:prod:bootstrap-super-admin": "node scripts/prod-bootstrap-admin.js --role super_admin",
    "deploy:prod:smoke": "node scripts/prod-stack-smoke.js",
    "deploy:prod:feature-sweep": "node scripts/prod-feature-sweep.js",
    "deploy:prod:ai-sweep": "node scripts/prod-ai-quality-sweep.js",
    "deploy:prod:s3:smoke": "node scripts/prod-stack-smoke.js --expect-storage-provider s3",
    "deploy:prod:edge:config": "docker compose -f docker-compose.prod.yml -f docker-compose.prod.edge.yml config",
    "deploy:prod:edge:up": "docker compose -f docker-compose.prod.yml -f docker-compose.prod.edge.yml up -d",
    "deploy:prod:edge:down": "docker compose -f docker-compose.prod.yml -f docker-compose.prod.edge.yml down",
    "deploy:prod:edge:logs": "docker compose -f docker-compose.prod.yml -f docker-compose.prod.edge.yml logs -f edge"
  }
}
